@startuml User_Flow_Activity
!theme plain
skinparam backgroundColor #1E1E2E
skinparam defaultFontColor #CDD6F4
skinparam activityBorderColor #585B70
skinparam arrowColor #89B4FA

title MIDAS — Main User Flow

|User|
start

:Launch application;
note right: Window opens maximized

|System|
:Display **page_hub**\n(central hub — initial page);
note right
    Two empty dataset slots
    (Base 1 & Base 2).
    Language selector in header.
end note

|User|
:Click empty slot or "Load" button;

|System|
:Open FileDialog\n(CSV / ARFF filter);

|User|
:Select a CSV or ARFF file;

|System|
if (Valid format?) then (yes)
    if (Format?) then (CSV)
        :Show delimiter dialog\n(auto / ; / , / tab);
        :Load CSV via CSVController;
        :Auto-typify attributes\n(infer_types_from_df);
        note right
            CSV has no type metadata,
            so types are inferred using
            ARFF-style categories:
            Numeric, Textual, Nominal, Date.
        end note
    else (ARFF)
        :Load ARFF via ARFFController;
        :Keep types from file\n(@ATTRIBUTE declarations);
    endif
    :Sync state → StateManager\n(syncFromCSV / syncFromARFF);
    :Update slot in hub;
else (no)
    :Show error dialog;
    stop
endif

|User|
repeat
    :View hub with slot(s) filled;
    note right
        Click a slot to select it.
        1 selected → View / Typify / Export
        2 selected → Merge
    end note

    if (How many selected?) then (1 slot)
        split
            :Click **View** action card;
            |System|
            :Push state to controller\n(pushPrimary|SecondaryToController);
            :Navigate → page_view;
            :Show paginated table;
            |User|
            :Browse / edit data\n(delete rows or columns);
            :Click Back;
        split again
            :Click **Typify** action card;
            |System|
            :Push state to controller;
            :Navigate → page_preprocess;
            |User|
            :Adjust attribute types\n(Nominal / Numeric / Textual / Date);
            :View histogram / stacked chart;
            :Confirm;
            |System|
            :Sync updated types to StateManager;
            :Pop back to hub;
        split again
            :Click **Export** action card;
            |System|
            :Open format dialog\n(ARFF / CSV);
            |User|
            :Choose format;
            |System|
            :Open save FileDialog;
            :Save via SerializationService;
        split again
            :Click **Load second base**;
            |System|
            :setLoadingSecondary();
            :Open FileDialog;
            |User|
            :Select file;
            |System|
            :Load into Base 2 slot;
            :Auto-typify if CSV;
        end split
    else (2 slots)
        :Click **Merge** action card;
        note right: Only enabled when both bases are typified

        |System|
        :Navigate → page_merge;

        :== Step 1: Map Columns ==;
        |User|
        :Define column correspondences;
        note right
            Map columns that represent
            the same data across bases.
            e.g. "customer_id" ↔ "id"
            Type compatibility is validated.
        end note

        :Click Next;

        :== Step 2: Configure Merge ==;
        |System|
        if (Has mappings?) then (yes)
            :Show all JOIN options;
            note right
                inner / left / right / cross
            end note
        else (no)
            :Only cross join available;
        endif

        |User|
        :Choose join type;
        :Select key column (if applicable);
        :Preview result;
        :Click Execute;

        |System|
        :MergeService.execute();
        :Result replaces primary;\nsecondary is cleared;
        :Show success popup\n(Export / Return without saving);

        if (User chooses?) then (Export)
            :Open save FileDialog;
            :Save merged dataset;
            :clearAllBases();
        else (Return)
            :clearAllBases();
        endif
        :Replace stack with hub;
    endif

repeat while (Continue using?) is (yes)

|User|
:Close application;

stop

@enduml
