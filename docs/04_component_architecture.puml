@startuml MIDAS_Component_Architecture
!theme plain
skinparam backgroundColor #1E1E2E
skinparam defaultFontColor #CDD6F4
skinparam componentStyle rectangle
skinparam ArrowColor #89B4FA
skinparam packageBorderColor #585B70
skinparam packageFontColor #CDD6F4
skinparam componentBorderColor #585B70
skinparam noteBorderColor #585B70
skinparam noteBackgroundColor #313244

title MIDAS — Component Architecture (MVC + Services)

' ============================================================
'   QML – Presentation layer
' ============================================================
package "QML  (Presentation)" as qml #1E1E2E {

    package "Components" as comp {
        [Theme.qml]            <<singleton>>
        [ActionCard.qml]
        [SectionCard.qml]
        [StandardDialog.qml]
    }

    package "Pages" as pages {
        [page_hub.qml]         <<central hub>>
        [page_load.qml]        <<splash / file picker>>
        [page_view.qml]        <<data table viewer>>
        [page_merge.qml]       <<merge config & preview>>
        [page_preprocess.qml]  <<type selection & charts>>
    }

    [main.qml]                 <<ApplicationWindow + StackView>>
}

' ============================================================
'   Python entry-point
' ============================================================
package "Entry Point" as entry #1E1E2E {
    [main.py]
    [LanguageManager]          <<QObject>>
}

' ============================================================
'   Controllers – QML-facing layer
' ============================================================
package "Controllers  (src/controllers)" as ctrl #1E1E2E {
    [StateManager]             <<QObject – facade>>
    [CSVController]            <<QObject>>
    [ARFFController]           <<QObject>>
    [NavigationController]     <<QObject>>
    [BaseDataController]       <<QObject – base class>>
}

' ============================================================
'   Services – Business logic (Qt-free)
' ============================================================
package "Services  (src/services)" as svc #1E1E2E {
    [MergeService]
    [SerializationService]
}

' ============================================================
'   Models – Data layer
' ============================================================
package "Models  (src/models)" as mdl #1E1E2E {
    [DatasetState]             <<value object>>
    [DataFrameModel]           <<QAbstractTableModel>>
}

' ============================================================
'   External libraries
' ============================================================
package "External" as ext #1E1E2E {
    [pandas]
    [numpy]
    [matplotlib]
    [liac-arff]
    [PySide6 / Qt 6]
}

' ============================================================
'   Relationships
' ============================================================

' Entry point
[main.py]            --> [LanguageManager]         : creates
[main.py]            --> [main.qml]                : loads via QQmlApplicationEngine
[main.py]            ..> ctrl                      : registers QML types\n(CSVController, ARFFController,\nStateManager, NavigationController)

' QML pages use controllers
[main.qml]           --> pages                     : pushes via StackView
pages                --> comp                      : uses Theme / ActionCard /\nSectionCard / StandardDialog

[page_hub.qml]       --> [StateManager]            : syncFromCSV / syncFromARFF\npushPrimary|SecondaryToController
[page_hub.qml]       --> [CSVController]           : loadCsv
[page_hub.qml]       --> [ARFFController]          : loadArff
[page_hub.qml]       --> [NavigationController]    : startLoad / goToView / goToMerge
[page_merge.qml]     --> [StateManager]            : executeMerge / previewMerge
[page_view.qml]      --> [CSVController]           : pagination, delete row/col
[page_view.qml]      --> [ARFFController]          : pagination, delete row/col
[page_preprocess.qml] --> [CSVController]          : type editing, chart data
[page_preprocess.qml] --> [ARFFController]         : type editing, chart data

' Controller internal hierarchy
[CSVController]      --|> [BaseDataController]     : inherits
[ARFFController]     --|> [BaseDataController]     : inherits

' StateManager facade pattern
[StateManager]       --> [MergeService]            : owns & delegates merge
[StateManager]       --> [SerializationService]    : delegates save
[StateManager]       --> [DatasetState]            : owns primary + secondary

' Services use models
[MergeService]       --> [DatasetState]            : reads / mutates
[SerializationService] --> [DatasetState]          : reads

' Models use external
[DatasetState]       ..> [pandas]                  : DataFrame storage
[DataFrameModel]     ..> [pandas]                  : DataFrame adapter
[BaseDataController] ..> [numpy]                   : statistics & histograms
[BaseDataController] ..> [matplotlib]              : chart rendering
[SerializationService] ..> [liac-arff]             : ARFF I/O
ctrl                 ..> [PySide6 / Qt 6]          : QObject, Slot, Property, Signal

' LanguageManager
[LanguageManager]    ..> [PySide6 / Qt 6]          : QTranslator

' ============================================================
'   Notes
' ============================================================
note bottom of svc
  Services are **Qt-free** — no QObject,
  no Signals. They operate on plain
  DatasetState and pandas DataFrames.
end note

note bottom of mdl
  **DatasetState** stores df, arff_attributes,
  selected_types, relation_name, etc.
  **infer_types_from_df()** auto-typifies CSV
  data using ARFF-style type categories.
end note

note right of [StateManager]
  Thin facade: exposes @Slot / Property
  for QML. Owns two DatasetState instances
  (primary & secondary) and delegates
  all heavy logic to MergeService and
  SerializationService.
end note

@enduml
