@startuml Merge_Sequence
!theme plain
skinparam backgroundColor #1E1E2E
skinparam defaultFontColor #CDD6F4
skinparam sequenceArrowColor #89B4FA
skinparam sequenceLifeLineBorderColor #585B70
skinparam participantBorderColor #585B70
skinparam participantBackgroundColor #313244
skinparam noteBorderColor #585B70
skinparam noteBackgroundColor #313244

title MIDAS — Merge Sequence Diagram

actor User
participant "page_hub" as Hub
participant "page_merge" as Merge
participant "StateManager" as SM
participant "MergeService" as MS
participant "SerializationService" as SS
participant "CSVController" as CSV
participant "pandas" as PD

== 1. Initial State — Load Primary Base ==

note over Hub
  App starts at Hub.
  Both slots empty.
end note

User -> Hub : Click empty slot 1
Hub -> Hub : FileDialog.open()
User -> Hub : Select CSV file
Hub -> Hub : delimiterDialog.open()
User -> Hub : Confirm delimiter

Hub -> CSV : loadCsv(url, delimiter)
CSV -> PD : read_csv(file)
PD --> CSV : DataFrame
CSV --> Hub : dataframeChanged

Hub -> SM : syncFromCSV(controller, fileName)
SM -> SM : _sync_state(primary, ...)\ninfer_types_from_df(df)
SM -> SM : primary.is_preprocessed = true
SM --> Hub : primaryBaseChanged

note over Hub
  Slot 1: Base loaded & typified
  Slot 2: Empty
end note

== 2. Load Secondary Base ==

User -> Hub : Click "+ Load second base"
Hub -> SM : setLoadingSecondary()

Hub -> Hub : FileDialog.open()
User -> Hub : Select second CSV file

Hub -> CSV : loadCsv(url, delimiter)
Hub -> SM : syncFromCSV(controller, fileName)
SM -> SM : _sync_state(secondary, ...)\ninfer_types_from_df(df)
SM -> SM : secondary.is_preprocessed = true
SM --> Hub : secondaryBaseChanged

note over Hub
  Slot 1: Base 1 (typified)
  Slot 2: Base 2 (typified)
  Merge card: enabled
end note

== 3. Configure Merge — Step 1: Column Mapping ==

User -> Hub : Select both slots\nClick "Merge" card
Hub -> Merge : stack.push("page_merge.qml")

note over Merge
  **Step 1: Map Columns**
  Define correspondences between
  columns of Base 1 and Base 2.
end note

User -> Merge : Map "name" ↔ "nome"
Merge -> SM : checkMappingCompatibility("name", "nome")
SM -> MS : check_mapping_compatibility(...)
MS --> SM : "" (compatible)
SM --> Merge : ""

Merge -> SM : addColumnMapping("name", "nome")
SM -> MS : add_mapping("name", "nome")
MS --> SM : (true, "")
SM --> Merge : columnMappingChanged

User -> Merge : Click "Next"

== 4. Configure Merge — Step 2: Join Settings ==

note over Merge
  **Step 2: Join Configuration**
  With mappings → all join options available.
end note

Merge -> SM : hasMappings()
SM --> Merge : true

Merge -> SM : getMappingsForDropdown()
SM --> Merge : ["nome / name"]

User -> Merge : Select "LEFT JOIN"
User -> Merge : Select key "nome / name"

== 5. Preview ==

User -> Merge : Click "Update preview"
Merge -> SM : getMappingPrimaryColumn("nome / name")
SM --> Merge : "nome"

Merge -> SM : previewMerge("nome", "LEFT JOIN")
SM -> MS : preview("nome", "LEFT JOIN")
MS -> PD : merge(df1.head(100), df2.head(100))
PD --> MS : sample_result
MS --> SM : {columns, data, totalRows, ...}
SM --> Merge : preview result

Merge -> User : Display preview table

== 6. Execute Merge ==

User -> Merge : Click "Execute"

Merge -> SM : executeMerge("nome", "LEFT JOIN")
SM -> MS : execute("nome", "LEFT JOIN")
MS -> PD : merge(df1, df2, on="nome", how="left")
PD --> MS : merged_df

MS -> MS : primary.df = merged_df\nsecondary.clear()\nmapping.clear()
MS --> SM : (true, "N rows, M columns")
SM --> Merge : mergeCompleted

Merge -> Merge : successPopup.open()\n"Export" / "Return without saving"

== 7. Post-Merge: Export or Return ==

alt User chooses "Export"
    User -> Merge : Click "Export"
    Merge -> Merge : mergeExportDialog.open()
    User -> Merge : Choose file path
    Merge -> SM : saveToFile(path)
    SM -> SS : save(primary, path)
    SS -> PD : to_csv / arff.dump
    SS --> SM : (true, "")
    Merge -> SM : clearAllBases()
else User chooses "Return without saving"
    User -> Merge : Click "Return"
    Merge -> SM : clearAllBases()
end

Merge -> Hub : stack.replace("page_hub.qml")

note over Hub
  Both slots cleared.
  Ready for new session.
end note

@enduml
