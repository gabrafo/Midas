@startuml State_Diagram
!theme plain
skinparam backgroundColor #1E1E2E
skinparam defaultFontColor #CDD6F4
skinparam stateBorderColor #585B70
skinparam stateBackgroundColor #313244
skinparam arrowColor #89B4FA
skinparam noteBorderColor #585B70
skinparam noteBackgroundColor #313244

title MIDAS — State Diagram

[*] --> Hub : App launches

state Hub as "Hub  (page_hub)" {
    [*] --> NoData

    NoData : No bases loaded
    NoData : Both slots empty

    state "One Base Loaded" as OneBase {
        [*] --> PrimaryLoaded
        PrimaryLoaded : Slot 1 filled
        PrimaryLoaded : Auto-typified (CSV)
        PrimaryLoaded : or typed from file (ARFF)

        PrimaryLoaded --> TwoBasesLoaded : Load 2nd base
    }

    state "Two Bases Loaded" as TwoBasesLoaded {
        [*] --> ReadyToMerge
        ReadyToMerge : Both typified
        ReadyToMerge : Merge card enabled
    }

    NoData --> OneBase : Load file
}

' --- File loading ---
state LoadingFile {
    [*] --> DetectFormat
    DetectFormat --> LoadingCSV : .csv
    DetectFormat --> LoadingARFF : .arff

    LoadingCSV --> DelimiterDialog : Show delimiter picker
    DelimiterDialog --> ParseCSV : User confirms
    ParseCSV --> AutoTypify : CSV loaded
    LoadingARFF --> UseARFFTypes : ARFF loaded

    AutoTypify : infer_types_from_df()
    AutoTypify : Numeric / Textual / Nominal / Date
    UseARFFTypes : Keep @ATTRIBUTE types

    AutoTypify --> Synced
    UseARFFTypes --> Synced

    Synced : syncFromCSV or syncFromARFF
    Synced : Mark preprocessed

    ParseCSV --> LoadError : Parse failure
    LoadingARFF --> LoadError : Parse failure
}

Hub --> LoadingFile : Click empty slot\nor "Load" button
LoadingFile --> Hub : Sync complete → update slot
LoadError --> Hub : Show error dialog

' --- View ---
state Viewing as "View  (page_view)" {
    [*] --> ShowTable
    ShowTable : Paginated table
    ShowTable : Horizontal & vertical scroll
    ShowTable : Delete rows or columns
}

' --- Typify ---
state Typifying as "Typify  (page_preprocess)" {
    [*] --> EditTypes
    EditTypes : Adjust per-column types
    EditTypes : View histograms & stacked charts
    EditTypes --> TypesConfirmed : Confirm
}

' --- Merge ---
state MergeConfig as "Merge  (page_merge)" {
    [*] --> Step1

    state "Step 1 — Column Mapping" as Step1 {
        [*] --> MappingColumns
        MappingColumns : Define correspondences
        MappingColumns : e.g. customer_id ↔ id
        MappingColumns : Type compatibility validated
    }

    Step1 --> Step2 : Next

    state "Step 2 — Join Configuration" as Step2 {
        [*] --> ChoosingJoin

        state ChoosingJoin {
            NoMappings : Cross join only
            WithMappings : inner / left / right / cross
            WithMappings : + key column selector
        }

        ChoosingJoin --> Preview : Update preview
    }

    Step2 --> Executing : Execute merge
}

state Executing as "Merge Execution" {
    [*] --> Processing
    Processing --> Success : MergeService.execute()
    Processing --> MergeError : Failure

    Success : Result → primary
    Success : Secondary cleared
    Success : Show success popup
}

state PostMerge as "Post-Merge Popup" {
    [*] --> UserChoice
    UserChoice --> ExportResult : Export
    UserChoice --> DiscardResult : Return without saving

    ExportResult : FileDialog → save
    ExportResult : clearAllBases()

    DiscardResult : clearAllBases()
}

' --- Transitions ---
Hub --> Viewing : View  (1 selected)
Hub --> Typifying : Typify  (1 selected)
Hub --> MergeConfig : Merge  (2 selected)

Viewing --> Hub : Back
Typifying --> Hub : Confirm / Cancel
MergeConfig --> Hub : Back (cancel)

Executing --> PostMerge : Success
MergeError --> MergeConfig : Show error
PostMerge --> Hub : Replace stack

' --- Notes ---
note right of AutoTypify
  CSV has no type metadata.
  Types are inferred with
  ARFF-style categories by
  analyzing the DataFrame.
end note

note right of Step1
  Mappings let the user
  rename columns from Base 2
  so they align with Base 1
  before the join.
end note

note right of ChoosingJoin
  Without mappings:
  → only cross join
  With mappings:
  → all 4 join types
end note

@enduml
